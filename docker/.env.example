# Environment for docker-compose.yml / docker-compose.full.yml.
# Copy to `.env` in this directory and edit. Run compose from this directory.

# Image tag to run (matches VERSION / a GHCR tag)
IMAGE_TAG=latest

# Server
SERVER_PORT=4000
CLIENT_NAME=omniwa
OS_NAME=OmniWA GO

# License gate: true = require activation (default), false = run independently
LICENSE_GATE_ENABLED=true

# Security — CHANGE THIS
GLOBAL_API_KEY=change-me

# PostgreSQL (host "postgres" is the compose service; DBs auto-created)
POSTGRES_AUTH_DB=postgresql://postgres:postgres@postgres:5432/omniwa_auth?sslmode=disable
POSTGRES_USERS_DB=postgresql://postgres:postgres@postgres:5432/omniwa_users?sslmode=disable
DATABASE_SAVE_MESSAGES=false

# Logs
WADEBUG=INFO
LOGTYPE=console
LOG_DIRECTORY=/app/logs

# Connection
CONNECT_ON_STARTUP=false
WEBHOOK_FILES=true

# Events
EVENT_IGNORE_GROUP=false
EVENT_IGNORE_STATUS=true
QRCODE_MAX_COUNT=5

# Optional integrations (enabled by docker-compose.full.yml)
WEBHOOK_URL=
AMQP_URL=
AMQP_GLOBAL_ENABLED=false
NATS_URL=
NATS_GLOBAL_ENABLED=false
MINIO_ENABLED=false
